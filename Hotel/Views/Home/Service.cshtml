@model IEnumerable<Hotel.Models.Service>
@{
    ViewData["Title"] = "Услуги";
}
<h2>Услуги</h2>
<form asp-controller="Home" asp-action="Service" method="Post" id="search" class="d-inline">
    <input type="text" name="column" />
    <select name="field" class="filter">
        <option value="name">название</option>
        <option value="id_st">id сотрудника</option>
        <option value="id_c">id клиента</option>
        <option value="date_of_registration">дата регистрации</option>
    </select>
    <input type="submit" value="Найти" class="btn btn-success w-30 p-1" />
</form>
<form asp-controller="Home" asp-action="InsertService" method="Get" class="d-inline">
    <input type="submit" value="Добавить" class="btn btn-success w-30 p-1" />
</form>
<div id="testTableContainer">@Html.Partial("_Service", Model)</div>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script>
    $(document).ready(function () {
        $('#search').submit(function (e) {
            e.preventDefault();
            $.ajax({
                url: '@Url.Action("Service", "Home")',
                type: 'POST',
                data: $(this).serialize(),
                success: function (data) {
                    $('#testTableContainer').html(data);
                },
                error: function (xhr, status, error) {
                    console.error(error);
                }
            });
        });
    });
</script>