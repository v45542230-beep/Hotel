@model IEnumerable<Hotel.Models.Personal>
@{
    ViewData["Title"] = "Персонал";
}
<h2>Персонал</h2>
<form asp-controller="Home" asp-action="Personal" method="Post" id="search" class="d-inline">
    <input type="text" name="column" />
    <select name="field" class="filter">
        <option value="fio">ФИО</option>
        <option value="name">должность</option>
        <option value="date_of_employment">дата найма</option>
    </select>
    <input type="submit" value="Найти" class="btn btn-success w-30 p-1" />
</form>
<div id="testTableContainer">@Html.Partial("_Personal", Model)</div>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script>
    $(document).ready(function () {
        $('#search').submit(function (e) {
            e.preventDefault();
            $.ajax({
                url: '@Url.Action("Personal", "Home")',
                type: 'POST',
                data: $(this).serialize(),
                success: function (data) {
                    $('#testTableContainer').html(data);
                },
                error: function (xhr, status, error) {
                    console.error(error);
                }
            });
        });
    });
</script>